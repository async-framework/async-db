      "kind": "publish_policy",
      "title": "Publish launch approval policy",
      "status": "ready",
      "readyAt": "2026-05-02T18:30:00.000Z",
      "completedAt": null,
      "notes": "All required approvals are in."
    },
    {
      "id": "action_enable_vendor_access",
      "changeRequestId": "cr_vendor_access",
      "ownerId": "mem_lina",
      "kind": "enable_access",
      "title": "Enable vendor workspace access",
      "status": "blocked",
      "readyAt": null,
      "completedAt": null,
      "notes": "Waiting for revised scope and compliance approval."
    }
  ]
}
