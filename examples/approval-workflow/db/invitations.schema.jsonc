      "status": "accepted",
      "reason": "Security should confirm the public launch checklist language.",
      "createdAt": "2026-05-01T17:05:00.000Z"
    },
    {
      "id": "invite_vendor_compliance",
      "changeRequestId": "cr_vendor_access",
