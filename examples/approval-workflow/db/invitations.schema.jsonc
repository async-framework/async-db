{
  "kind": "collection",
  "idField": "id",
  "description": "Invitations for teams or specific reviewers to join a change request.",
  "fields": {
    "id": {
      "type": "string",
      "required": true
    },
    "changeRequestId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "changeRequest",
        "to": "changeRequests",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "invitedById": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "invitedBy",
        "to": "members",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "inviteeMemberId": {
      "type": "string",
      "nullable": true,
      "relation": {
        "name": "inviteeMember",
        "to": "members",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "inviteeTeamId": {
      "type": "string",
      "nullable": true,
      "relation": {
        "name": "inviteeTeam",
        "to": "teams",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "status": {
      "type": "enum",
      "values": ["pending", "accepted", "declined"],
      "default": "pending"
    },
    "reason": {
      "type": "string"
    },
    "createdAt": {
      "type": "datetime"
    }
  },
  "seed": [
    {
      "id": "invite_launch_security",
