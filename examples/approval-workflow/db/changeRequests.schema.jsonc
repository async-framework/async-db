{
  "kind": "collection",
  "idField": "id",
  "description": "Human change requests that need invited reviewers and approval gates.",
  "fields": {
    "id": {
      "type": "string",
      "required": true
    },
    "key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "summary": {
      "type": "string"
    },
    "requestType": {
      "type": "enum",
      "values": ["policy", "process", "access"],
      "default": "process"
    },
    "status": {
      "type": "enum",
      "values": ["open", "changes_requested", "approved", "action_ready", "completed"],
      "default": "open"
    },
    "requesterId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "requester",
        "to": "members",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "targetTeamId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "targetTeam",
        "to": "teams",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "actionIntent": {
      "type": "string"
    },
    "createdAt": {
      "type": "datetime"
    }
  },
  "seed": [
    {
      "id": "cr_launch_policy",
