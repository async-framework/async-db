      "status": "action_ready",
      "requesterId": "mem_ana",
      "targetTeamId": "team_product_ops",
      "actionIntent": "Publish the revised launch checklist",
      "createdAt": "2026-05-01T16:30:00.000Z"
    },
    {
      "id": "cr_vendor_access",
      "key": "CR-1002",
      "title": "Approve vendor workspace access",
      "summary": "Requests temporary workspace access for a support vendor during onboarding.",
