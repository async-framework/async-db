{
  "version": 1,
  "collections": {
    "projects": {
      "kind": "collection",
      "name": "projects",
      "fields": {
        "id": {
          "type": "string",
          "required": true,
          "nullable": false,
          "description": "Stable project id."
        },
        "name": {
          "type": "string",
          "required": true,
          "nullable": false,
          "description": "Project display name."
        },
        "ownerId": {
          "type": "string",
          "required": true,
          "nullable": false,
          "description": "Owner user id.",
          "relation": {
            "name": "owner",
            "to": "users",
            "toField": "id",
            "cardinality": "one"
          }
        },
        "status": {
          "type": "enum",
          "required": false,
          "nullable": false,
          "description": "Workflow status for local admin forms.",
          "default": "planned",
          "values": [
            "planned",
            "active",
            "paused",
            "done"
          ],
          "schemaUi": {
            "component": "segmented-control"
          }
        },
        "notes": {
          "type": "string",
          "required": false,
          "nullable": false,
          "description": "Internal project notes.",
          "maxLength": 500
        }
      },
      "description": "Projects used to demonstrate generated form metadata.",
      "idField": "id"
    },
    "users": {
      "kind": "collection",
      "name": "users",
      "fields": {
        "id": {
          "type": "string",
          "required": true,
          "nullable": false,
          "description": "Stable user id."
        },
        "name": {
          "type": "string",
          "required": true,
          "nullable": false,
          "description": "Display name."
        },
        "email": {
          "type": "string",
          "required": true,
          "nullable": false,
          "description": "Email shown in admin forms.",
          "unique": true
        },
        "bio": {
          "type": "string",
          "required": false,
          "nullable": false,
          "description": "Markdown biography for profile previews.",
          "schemaUi": {
            "component": "markdown"
          }
        }
      },
      "description": "People who can own local projects.",
      "idField": "id"
    }
  },
  "documents": {}
}
