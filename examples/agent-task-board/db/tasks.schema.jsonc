{
  "kind": "collection",
  "idField": "id",
  "description": "Requested work that an agent can run.",
  "fields": {
    "id": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "enum",
      "values": ["queued", "running", "blocked", "done"],
      "default": "queued"
    },
    "requester": {
      "type": "string"
    },
    "priority": {
      "type": "enum",
      "values": ["low", "medium", "high"],
      "default": "medium"
    },
    "agentId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "agent",
        "to": "agents",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "createdAt": {
      "type": "datetime"
    }
  },
