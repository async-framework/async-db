{
  "kind": "collection",
  "idField": "id",
  "description": "Conflicts between accepted memory and newer or older claims.",
  "fields": {
    "id": {
      "type": "string",
      "required": true
    },
    "memoryId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "memory",
        "to": "memories",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "claimId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "claim",
        "to": "claims",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "status": {
      "type": "enum",
      "values": ["open", "resolved"],
      "default": "open"
    },
    "summary": {
      "type": "string"
    }
  },
  "seed": [
    {
      "id": "conflict_support_hours",
      "memoryId": "mem_support_hours",
      "claimId": "claim_old_support_hours",
      "status": "open",
      "summary": "Older coverage note conflicts with the current 6 PM support memory."
    }
  ]
}
