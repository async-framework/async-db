    },
    "memorySpaceId": {
      "type": "string",
      "required": true,
      "relation": {
        "name": "memorySpace",
        "to": "memorySpaces",
        "toField": "id",
        "cardinality": "one"
      }
    },
    "sourceId": {
      "type": "string",
      "nullable": true,
      "relation": {
        "name": "source",
        "to": "sources",
