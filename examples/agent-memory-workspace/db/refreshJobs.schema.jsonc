        "cardinality": "one"
      }
    },
    "status": {
      "type": "enum",
      "values": ["queued", "running", "completed", "failed"],
      "default": "queued"
    },
    "reason": {
      "type": "string"
    },
    "scheduledFor": {
      "type": "datetime"
    }
  },
  "seed": [
    {
