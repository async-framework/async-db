    },
    "email": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "segment": {
      "type": "enum",
      "values": ["retail", "wholesale", "vip"],
      "default": "retail"
    },
