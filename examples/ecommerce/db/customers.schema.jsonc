          "required": true
        },
        "city": {
          "type": "string",
          "required": true
        },
        "region": {
          "type": "string",
          "required": true
        },
        "postalCode": {
          "type": "string",
          "required": true
        },
        "country": {
          "type": "string",
          "required": true
        }
      }
    },
    "createdAt": {
      "type": "datetime",
      "required": true
    }
  },
